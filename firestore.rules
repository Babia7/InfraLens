rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // InfraLens user profiles (private to owner).
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Shared app content is currently read-only for all signed-in users.
    match /content/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny for any collections not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
